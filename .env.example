# 🏆 Daon (다온) Environment Variables Template
# Copy this file to '.env' and fill in your actual credentials.

# Google Gemini API Key
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# PostgreSQL Database Connection Configuration
DB_HOST=host.docker.internal
DB_PORT=5432
DB_USER=daon_user
DB_PASSWORD=your_strong_password
DB_NAME=daondb

# Public Data Portal API Key (복지로 공공 API 인증키)
DATA_PORTAL_API_KEY=YOUR_DATA_PORTAL_API_KEY_HERE
LOCAL_WELFARE_API_KEY=YOUR_LOCAL_WELFARE_API_KEY_HERE
